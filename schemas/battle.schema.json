{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Battle",
  "description": "Schema for battle data",
  "type": "object",
  "required": ["battle_time", "battle_type", "result"],
  "properties": {
    "battle_time": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of battle"
    },
    "battle_type": {
      "type": "string",
      "enum": ["solo", "duo", "team", "challenge"],
      "description": "Type of battle"
    },
    "result": {
      "type": "string",
      "enum": ["victory", "defeat", "draw"],
      "description": "Battle result"
    },
    "trophies_change": {
      "type": "integer",
      "description": "Trophy change after battle (can be negative)"
    },
    "brawler_id": {
      "type": "integer",
      "description": "Brawler ID used in battle"
    },
    "brawler_name": {
      "type": "string",
      "description": "Brawler name used in battle"
    },
    "map_name": {
      "type": "string",
      "description": "Map name where battle took place"
    },
    "game_mode": {
      "type": "string",
      "enum": ["Showdown", "Gem Grab", "Heist", "Bounty", "Hot Zone", "Knockout", "Brawl Ball", "Volleyball", "Basketball", "Wipeout", "Payload"],
      "description": "Game mode of the battle"
    },
    "teammates": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Array of teammate player tags"
    },
    "opponents": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Array of opponent player tags"
    },
    "rank_position": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Rank position in Showdown battles"
    }
  }
}
