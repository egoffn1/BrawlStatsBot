{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClubHistory",
  "description": "Schema for club history data",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["date", "trophies"],
    "properties": {
      "date": {
        "type": "string",
        "format": "date",
        "description": "Date in YYYY-MM-DD format"
      },
      "trophies": {
        "type": "integer",
        "minimum": 0,
        "description": "Club trophy count on that date"
      },
      "member_count": {
        "type": "integer",
        "minimum": 1,
        "maximum": 30,
        "description": "Number of members on that date"
      },
      "required_trophies": {
        "type": "integer",
        "minimum": 0,
        "description": "Required trophies to join on that date"
      }
    }
  }
}
