{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TeamStats",
  "description": "Schema for team statistics",
  "type": "object",
  "required": ["player_tags", "total_battles"],
  "properties": {
    "player_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^#[0-9A-Za-z]{3,}$"
      },
      "minItems": 2,
      "maxItems": 3,
      "description": "Array of player tags in the team"
    },
    "total_battles": {
      "type": "integer",
      "minimum": 1,
      "description": "Total battles played together"
    },
    "total_wins": {
      "type": "integer",
      "minimum": 0,
      "description": "Total wins together"
    },
    "win_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Win rate percentage"
    },
    "favorite_game_modes": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Most played game modes"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    }
  }
}
