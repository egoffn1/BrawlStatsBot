```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
.env
.env.local
.env.*

# Logs and temporary files
*.log
*.tmp
*.swp

# Build artifacts
dist/
build/
*.egg-info/

# Editors
.vscode/
.idea/
*.swo
*.swn

# Coverage reports
.coverage
htmlcov/
coverage/

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/

# OS generated files
.DS_Store
Thumbs.db
```